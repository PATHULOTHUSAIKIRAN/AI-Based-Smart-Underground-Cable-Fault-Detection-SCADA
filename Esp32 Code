            document.getElementById('health-readout').innerText = sysData.health + '%';
            document.getElementById('health-readout').style.color = sysData.health > 80 ? 'lime' : (sysData.health > 50 ? 'orange' : 'red');
            document.getElementById('batt-val').innerText = (sysData.Battery || 8.2).toFixed(1);
            
            document.getElementById('val-vr').innerText = (sysData.Vr || 0).toFixed(1) + 'V';
            document.getElementById('val-vy').innerText = (sysData.Vy || 0).toFixed(1) + 'V';
            document.getElementById('val-vb').innerText = (sysData.Vb || 0).toFixed(1) + 'V';

            document.getElementById('stat-r').style.color = (sysData.Vr < 4.5) ? 'red' : 'lime';
            document.getElementById('stat-y').style.color = (sysData.Vy < 4.5) ? 'red' : 'lime';
            document.getElementById('stat-b').style.color = (sysData.Vb < 4.5) ? 'red' : 'lime';

            document.getElementById('auto-btn').innerText = sysData.auto_detect ? "AUTO: ON" : "AUTO: OFF";
            document.getElementById('auto-btn').style.background = sysData.auto_detect ? "var(--text-main)" : "#222";
            document.getElementById('auto-btn').style.color = sysData.auto_detect ? "#000" : "#fff";

            ['RG1','YG1','BG1','RY1','YB1','RB1','RG2','YG2','BG2','RY2','YB2','RB2'].forEach(key => {
                let btn = document.getElementById(`btn-${key}`);
                if (btn && sysData.relays) {
                    if (sysData.relays[key] == 1) btn.classList.add('active-fault');
                    else btn.classList.remove('active-fault');
                }
            });

            document.getElementById('ai-fault-type').innerText = sysData.active_fault || "NONE";
            document.getElementById('ai-fault-type').style.color = (sysData.active_fault && sysData.active_fault !== "NONE") ? "red" : "lime";
            
            // Populates explicitly with RG1, RY1, etc.
            document.getElementById('ai-phases').innerText = sysData.exact_relays || "N/A";
            
            document.getElementById('ai-risk').innerText = (sysData.failure_probability || 0) + '%';
            document.getElementById('ai-risk').style.color = sysData.failure_probability > 50 ? "red" : "lime";
            document.getElementById('ai-maint').innerText = sysData.maintenance_priority || "ROUTINE";
            document.getElementById('ai-maint').style.color = sysData.maintenance_priority == "URGENT" ? "red" : "lime";
            
            document.getElementById('ai-cause').innerText = sysData.cause || "N/A";
            document.getElementById('ai-sev').innerText = sysData.severity || "NORMAL";
            document.getElementById('ai-sev').style.color = sysData.severity == "NORMAL" ? "lime" : "red";
            document.getElementById('ai-confidence').innerText = (sysData.ai_confidence || 100) + '%';
            document.getElementById('ai-recommendation').innerText = sysData.ai_recommendation || "System Operating Nominally";

            // Corrected Mapping alignment to the exact text spacing (33.3% and 66.6%)
            const pointer = document.getElementById('map-fault-pointer');
            if (sysData.active_fault && sysData.active_fault !== "NONE") {
                pointer.style.display = 'block';
                pointer.style.left = sysData.fault_distance == 1 ? '33.3%' : '66.6%';
            } else {
                pointer.style.display = 'none';
            }

            if (sysData.active_fault && sysData.active_fault !== "NONE" && lastLoggedFault !== sysData.active_fault + sysData.fault_distance) {
                logEvent("FAULT", `${sysData.active_fault} @ ${sysData.fault_distance}km`, "red");
                lastLoggedFault = sysData.active_fault + sysData.fault_distance;
            } else if ((!sysData.active_fault || sysData.active_fault === "NONE") && lastLoggedFault !== null) {
                logEvent("CLEAR", "System nominal", "lime");
                lastLoggedFault = null;
            }
        }

        function sendCommand(id) {
            let newState = sysData.relays[id] == 1 ? 0 : 1;
            fetch('/api/trigger_relay', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({id: id, state: newState}) });
        }
        function toggleAuto() { fetch('/api/toggle_auto', { method: 'POST' }); }
        function startCompetition() { fetch('/api/competition_demo', { method: 'POST' }); }
        
        function emergencyStop() {
            ['RG1','YG1','BG1','RY1','YB1','RB1','RG2','YG2','BG2','RY2','YB2','RB2'].forEach(key => {
                if (sysData.relays[key] == 1) fetch('/api/trigger_relay', { method: 'POST', headers: {'Content-Type': 'application/json'}, body: JSON.stringify({id: key, state: 0}) });
            });
        }
        function logEvent(type, details, color) { document.getElementById('log-table').insertAdjacentHTML('afterbegin', `<tr><td>${new Date().toLocaleTimeString()}</td><td style="color:${color}; font-weight:bold;">${type}</td><td>${details}</td></tr>`); }

        const wCtx = document.getElementById('waveCanvas').getContext('2d');
        const pCtx = document.getElementById('phasorCanvas').getContext('2d');
        const tCtx = document.getElementById('trendCanvas').getContext('2d');
        let timeTracker = 0;

        function resizeCanvases() {
            [wCtx, pCtx, tCtx].forEach(c => { c.canvas.width = c.canvas.parentElement.clientWidth; c.canvas.height = c.canvas.parentElement.clientHeight; });
        }
        window.addEventListener('resize', resizeCanvases); setTimeout(resizeCanvases, 100);

        function drawSystem() {
            timeTracker += 0.05; 
            if (wCtx.canvas.width > 0) drawWaves(sysData.Vr || 5, sysData.Vy || 5, sysData.Vb || 5);
            if (pCtx.canvas.width > 0) drawPhasors(sysData);
            if (tCtx.canvas.width > 0) drawTrends();
            requestAnimationFrame(drawSystem);
        }

        function drawWaves(vR, vY, vB) {
            let w = wCtx.canvas.width, h = wCtx.canvas.height, midY = h / 2;
            wCtx.clearRect(0, 0, w, h); wCtx.strokeStyle = '#333'; wCtx.beginPath(); wCtx.moveTo(0, midY); wCtx.lineTo(w, midY); wCtx.stroke();
            drawSingleWave(wCtx, '#ff4444', vR, 0, timeTracker, w, midY); drawSingleWave(wCtx, '#ffcc00', vY, 2.094, timeTracker, w, midY); drawSingleWave(wCtx, '#33b5e5', vB, 4.188, timeTracker, w, midY);
        }
        function drawSingleWave(ctx, color, amp, phaseOffset, time, w, midY) {
            ctx.strokeStyle = color; ctx.lineWidth = 2; ctx.beginPath();
            for(let x=0; x<w; x++) { let y = midY - (amp * 10 * Math.sin((x * 0.05) - time + phaseOffset)); if(x===0) ctx.moveTo(x,y); else ctx.lineTo(x,y); }
            ctx.stroke();
        }

        function drawTrends() {
            let w = tCtx.canvas.width, h = tCtx.canvas.height;
            tCtx.clearRect(0,0,w,h); tCtx.strokeStyle='#333'; tCtx.strokeRect(0,0,w,h);
            if (sysHistory && sysHistory.Vr) {
                dt(tCtx, sysHistory.Vr, '#ff4444', w, h); dt(tCtx, sysHistory.Vy, '#ffcc00', w, h); dt(tCtx, sysHistory.Vb, '#33b5e5', w, h);
            }
        }
        function dt(ctx, arr, c, w, h) { 
            if(!arr || !arr.length) return; 
            ctx.strokeStyle=c; ctx.lineWidth=2; ctx.beginPath(); 
            let step = w / 60;
            for(let i=0; i<arr.length; i++) { let x = i * step; let y = h - (arr[i] / 6.0 * h); if(i==0) ctx.moveTo(x,y); else ctx.lineTo(x,y); }
            ctx.stroke(); 
        }

        function drawPhasors(data) {
            let w = pCtx.canvas.width, h = pCtx.canvas.height, cx = w / 2, cy = h / 2, maxRadius = Math.min(cx, cy) - 10;
            pCtx.clearRect(0, 0, w, h); pCtx.strokeStyle = '#222'; pCtx.beginPath(); pCtx.arc(cx, cy, maxRadius, 0, 6.28); pCtx.stroke();
            let aR = 0, aY = 2.094, aB = 4.188;
            drawVector(pCtx, cx, cy, aR, (data.Vr||0) * (maxRadius/6), '#ff4444', 3); drawVector(pCtx, cx, cy, aY, (data.Vy||0) * (maxRadius/6), '#ffcc00', 3); drawVector(pCtx, cx, cy, aB, (data.Vb||0) * (maxRadius/6), '#33b5e5', 3);
        }
        function drawVector(ctx, cx, cy, angle, length, color, width) {
            let ex = cx + length * Math.cos(angle), ey = cy + length * Math.sin(angle);
            ctx.strokeStyle = color; ctx.lineWidth = width; ctx.beginPath(); ctx.moveTo(cx, cy); ctx.lineTo(ex, ey); ctx.stroke();
            ctx.fillStyle = color; ctx.beginPath(); ctx.arc(ex, ey, width*1.5, 0, 6.28); ctx.fill();
        }

        drawSystem();
    </script>
</body>
</html>
)rawliteral";

