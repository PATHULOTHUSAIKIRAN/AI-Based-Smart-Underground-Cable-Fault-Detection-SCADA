void updateRelayState(String id, int state) {
  int pin = -1;
  if (id == "RG1") pin = RELAY_RG1; else if (id == "RY1") pin = RELAY_RY1;
  else if (id == "YG1") pin = RELAY_YG1; else if (id == "YB1") pin = RELAY_YB1;
  else if (id == "BG1") pin = RELAY_BG1; else if (id == "RB1") pin = RELAY_RB1;
  else if (id == "RG2") pin = RELAY_RG2; else if (id == "RY2") pin = RELAY_RY2;
  else if (id == "YG2") pin = RELAY_YG2; else if (id == "YB2") pin = RELAY_YB2;
  else if (id == "BG2") pin = RELAY_BG2; else if (id == "RB2") pin = RELAY_RB2;

  if (pin != -1) {
    relayStates[id] = state;
    digitalWrite(pin, state == 1 ? HIGH : LOW);
  }
}

// ================= 6. SETUP FUNCTION =================
void setup() {
  Serial.begin(115200);

  for(int i = 0; i < HISTORY_SIZE; i++) { hist_Vr[i] = 5.0; hist_Vy[i] = 5.0; hist_Vb[i] = 5.0; }

  pinMode(RELAY_RG1, OUTPUT); pinMode(RELAY_RY1, OUTPUT); pinMode(RELAY_YG1, OUTPUT); 
  pinMode(RELAY_YB1, OUTPUT); pinMode(RELAY_BG1, OUTPUT); pinMode(RELAY_RB1, OUTPUT);
  pinMode(RELAY_RG2, OUTPUT); pinMode(RELAY_RY2, OUTPUT); pinMode(RELAY_YG2, OUTPUT); 
  pinMode(RELAY_YB2, OUTPUT); pinMode(RELAY_BG2, OUTPUT); pinMode(RELAY_RB2, OUTPUT);

  pinMode(VR_PIN, INPUT); pinMode(VY_PIN, INPUT); pinMode(VB_PIN, INPUT); pinMode(BATT_PIN, INPUT);

  WiFi.begin(ssid, password);
  while (WiFi.status() != WL_CONNECTED) { delay(500); Serial.print("."); }
  Serial.println("\nWiFi Connected! IP: "); Serial.println(WiFi.localIP());

  server.on("/", []() { server.send(200, "text/html", index_html); });

  server.on("/api/data", []() {
    StaticJsonDocument<256> doc;
    doc["Vr"] = Vr; doc["Vy"] = Vy; doc["Vb"] = Vb;
    doc["Mode"] = auto_detect ? "AUTO" : "MANUAL";
    String response; serializeJson(doc, response);
    server.send(200, "application/json", response);
  });

  // Fallback endpoint to prevent 404s if user accidentally navigates away
  server.on("/api/download_csv", []() {
      String csv = "Error: Please use the CSV Export button on the dashboard to generate the log.";
      server.send(200, "text/plain", csv);
  });

  server.on("/api/ai_sync", HTTP_POST, []() {
    if (server.hasArg("plain") == false) { server.send(400, "text/plain", "Body not received"); return; }
    DynamicJsonDocument doc(1024);
    deserializeJson(doc, server.arg("plain"));
    
    if (doc.containsKey("health")) ai_health = doc["health"].as<float>();
    if (doc.containsKey("severity")) ai_severity = doc["severity"].as<String>();
    if (doc.containsKey("fault_type")) ai_fault_type = doc["fault_type"].as<String>();
    if (doc.containsKey("phase")) ai_fault_phase = doc["phase"].as<String>();
    if (doc.containsKey("risk")) ai_risk = doc["risk"].as<float>();
    if (doc.containsKey("maint")) ai_maint = doc["maint"].as<String>();
    if (doc.containsKey("cause")) ai_cause = doc["cause"].as<String>();
    if (doc.containsKey("recommendation")) ai_recommendation = doc["recommendation"].as<String>();
    if (doc.containsKey("distance")) ai_fault_distance = doc["distance"].as<int>();
    
    // IMPORTANT: Simulated Python Overrides have been REMOVED here. 
    // The ESP32 is reading physical voltages exclusively.

    server.send(200, "text/plain", "OK");
  });

  server.on("/api/trigger_relay", HTTP_POST, []() {
    if (server.hasArg("plain")) {
      StaticJsonDocument<256> doc;
      deserializeJson(doc, server.arg("plain"));
      String id = doc["id"];
      int state = doc["state"];
      updateRelayState(id, state);
      server.send(200, "text/plain", "OK");
    } else { server.send(400); }
  });

  server.on("/api/toggle_auto", HTTP_POST, []() {
    auto_detect = !auto_detect;
    server.send(200, "text/plain", "OK");
  });

  server.on("/api/dashboard_data", []() {
    DynamicJsonDocument doc(4096);
    
    JsonObject state = doc.createNestedObject("state");
    state["Vr"] = Vr; state["Vy"] = Vy; state["Vb"] = Vb; state["Battery"] = Battery;
    state["auto_detect"] = auto_detect;
    state["health"] = ai_health;
    state["severity"] = ai_severity;
    state["active_fault"] = ai_fault_type;
    state["fault_phase"] = ai_fault_phase;
    state["failure_probability"] = ai_risk;
    state["maintenance_priority"] = ai_maint;
    state["cause"] = ai_cause;
    state["ai_confidence"] = ai_confidence;
    state["ai_recommendation"] = ai_recommendation;
    state["fault_distance"] = ai_fault_distance;

    // Constructs Explicit Name List (e.g. RG1, RY1)
    String activeRelays = "";
    for (auto const& x : relayStates) {
        if(x.second == 1) {
            if(activeRelays.length() > 0) activeRelays += ", ";
            activeRelays += x.first;
        }
    }
    if(activeRelays == "") activeRelays = "N/A";
    state["exact_relays"] = activeRelays;

    JsonObject relays = state.createNestedObject("relays");
    for (auto const& x : relayStates) { relays[x.first] = x.second; }

    JsonObject history = doc.createNestedObject("history");
    JsonArray hVr = history.createNestedArray("Vr");
    JsonArray hVy = history.createNestedArray("Vy");
    JsonArray hVb = history.createNestedArray("Vb");
    for(int i=0; i<HISTORY_SIZE; i++) {
        hVr.add(hist_Vr[i]); hVy.add(hist_Vy[i]); hVb.add(hist_Vb[i]);
    }

    String response; serializeJson(doc, response);
    server.send(200, "application/json", response);
  });

  server.begin();
}

// ================= 7. MAIN LOOP =================
void loop() {
  server.handleClient();
  unsigned long currentMillis = millis();

  if (WiFi.status() != WL_CONNECTED && (currentMillis - lastWiFiCheck >= 5000)) {
    Serial.println("⚠️ Wi-Fi Dropped! Reconnecting...");
    WiFi.disconnect(); WiFi.reconnect();
    lastWiFiCheck = currentMillis;
  }

  // 🔥 IMPORTANT: Hardware Readings are turned BACK ON.
  // The system relies on physical voltage sensors connected to pins 35, 32, and 33.
  Vr = (analogRead(VR_PIN) / 4095.0) * 5.0; 
  Vy = (analogRead(VY_PIN) / 4095.0) * 5.0;
  Vb = (analogRead(VB_PIN) / 4095.0) * 5.0;
  Battery = (analogRead(BATT_PIN) / 4095.0) * 12.0;

  if (currentMillis - lastHistoryUpdate >= 1000) {
    for(int i = 0; i < HISTORY_SIZE - 1; i++) {
      hist_Vr[i] = hist_Vr[i+1];
      hist_Vy[i] = hist_Vy[i+1];
      hist_Vb[i] = hist_Vb[i+1];
    }
    hist_Vr[HISTORY_SIZE - 1] = Vr;
    hist_Vy[HISTORY_SIZE - 1] = Vy;
    hist_Vb[HISTORY_SIZE - 1] = Vb;

    lastHistoryUpdate = currentMillis;
  }
} 
