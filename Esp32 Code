    <script>
        setInterval(() => { document.getElementById('real-time-clock').innerText = new Date().toLocaleTimeString('en-US', { hour12: true }); }, 1000);

        function downloadCSV() {
            let rows = document.querySelectorAll('#main-log tr');
            let csvContent = "";
            rows.forEach(row => {
                let cols = row.querySelectorAll('td, th');
                let rowData = [];
                cols.forEach(col => rowData.push('"' + col.innerText + '"'));
                csvContent += rowData.join(",") + "\n";
            });
            let blob = new Blob([csvContent], { type: 'text/csv;charset=utf-8;' });
            let url = URL.createObjectURL(blob);
            let link = document.createElement("a");
            link.setAttribute("href", url);
            link.setAttribute("download", "scada_hmi_dashboard_log.csv");
            document.body.appendChild(link);
            link.click();
            document.body.removeChild(link);
        }

        let sysData = { Vr: 5.0, Vy: 5.0, Vb: 5.0, Battery: 8.2, relays: {}, exact_relays: "N/A" };
